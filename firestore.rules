rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // En desarrollo: permitir todo (CAMBIAR EN PRODUCCIÓN)
    match /{document=**} {
      allow read, write: if true;
    }

    // === REGLAS DE PRODUCCIÓN (descomentar cuando tengas auth) ===
