    // match /productos/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /ventas/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /pedidos/{id} {
    //   allow read, write: if request.auth != null;
    // }
    // match /movimientos/{id} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
